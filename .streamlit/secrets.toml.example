# 範例檔（可進版控）。實際使用請複製成 secrets.toml 並填入真值：
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
# secrets.toml 已被 .gitignore 忽略，不會外洩。
#
# 部署到 Streamlit Community Cloud 時，請把下列內容貼到
# App settings → Secrets（不要放進 repo）。

# --- Gemini AI 報告用金鑰（選填）---
# 於 https://aistudio.google.com 免費申請。
# 註：若 app 為公開部署，建議不要在伺服器端設此金鑰，改讓使用者自帶，
#     以免任何人都在消耗你的額度。
GEMINI_API_KEY = "your-gemini-api-key-here"

# --- Google 帳號登入（OIDC）---
# 設定 [auth] 後，app 會強制登入；未設定則不啟用登入（本機開發用）。
# client_id / client_secret 於 Google Cloud Console 建立 OAuth 2.0 用戶端後取得：
#   https://console.cloud.google.com/apis/credentials
# 授權的重新導向 URI 需與 redirect_uri 完全一致。
[auth]
# 本機開發：http://localhost:8501/oauth2callback
# 正式部署：https://<你的網域>/oauth2callback
redirect_uri = "http://localhost:8501/oauth2callback"
# 用強隨機字串，例如：python -c "import secrets; print(secrets.token_hex(32))"
cookie_secret = "please-generate-a-strong-random-string"
client_id = "xxxxxxxx.apps.googleusercontent.com"
client_secret = "xxxxxxxx"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# --- 授權白名單（選填但強烈建議）---
# 只有清單內的 Google 帳號能使用；留空或不設則任何登入者皆可進入。
allowed_emails = [
  "someone@yourcompany.com",
  "another@yourcompany.com",
]
